{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["../shared/src/*"],
      "@core/*": ["../core/src/*"],
      "@collab/*": ["../collab/src/*"],
      "@worker/*": ["../worker/src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
