{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../shared/src/*"],
      "@core/*": ["../core/src/*"],
      "@collab/*": ["../collab/src/*"],
      "@worker/*": ["../worker/src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
