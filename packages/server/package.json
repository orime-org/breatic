{
  "name": "@breatic/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@breatic/core": "workspace:*",
    "@breatic/shared": "workspace:*",
    "@hono/node-server": "^1.14.0",
    "@hono/zod-validator": "^0.7.6",
    "ai": "^6.0.141",
    "google-auth-library": "^10.6.2",
    "hono": "^4.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@breatic/collab": "workspace:*",
    "@breatic/worker": "workspace:*",
    "@hocuspocus/server": "^3.4.4",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^22.0.0",
    "bullmq": "^5.30.0",
    "postgres": "^3.4.0",
    "testcontainers": "^11.14.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0",
    "yjs": "^13.6.30"
  }
}
