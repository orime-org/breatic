# ── Stage 1: Build frontend ──────────────────────────────────────────
FROM node:22-slim AS builder

RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

WORKDIR /app

# Copy workspace config + package.json files
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml .npmrc ./
COPY packages/shared/package.json packages/shared/
COPY packages/server/package.json packages/server/
COPY packages/collab/package.json packages/collab/
COPY packages/web/package.json packages/web/

RUN pnpm install --frozen-lockfile --ignore-scripts=false

# Copy source
COPY packages/ packages/
COPY tsconfig.base.json turbo.json ./
COPY locales/ locales/

# Build shared (dependency) then web
RUN pnpm turbo build --filter=@breatic/shared

# VITE_ env vars are baked in at build time.
# Self-hosted: use your domain (e.g. https://www.example.com/api)
# Local dev: http://localhost:3000 / ws://localhost:1234
ARG VITE_API_URL=http://localhost:3000
ARG VITE_WS_URL=ws://localhost:1234
ARG VITE_BASE_URL=
ARG VITE_LOGIN_MODE=WithAccount
ARG VITE_APP_VERSION=0.1.0

ENV VITE_API_URL=${VITE_API_URL} \
    VITE_WS_URL=${VITE_WS_URL} \
    VITE_BASE_URL=${VITE_BASE_URL} \
    VITE_LOGIN_MODE=${VITE_LOGIN_MODE} \
    VITE_APP_VERSION=${VITE_APP_VERSION}

# Override base to "/" for self-hosted (nginx serves at root)
RUN cd packages/web && pnpm build -- --base=/

# ── Stage 2: Serve with nginx ───────────────────────────────────────
FROM nginx:1.27-alpine

# Install logrotate for daily log rotation
RUN apk add --no-cache logrotate

# Remove default config
RUN rm /etc/nginx/conf.d/default.conf

# Copy both HTTP and HTTPS templates + shared locations
COPY docker/nginx.conf /etc/nginx/templates/nginx.conf
COPY docker/nginx-ssl.conf /etc/nginx/templates/nginx-ssl.conf
COPY docker/breatic-locations.conf /etc/nginx/conf.d/breatic-locations.conf

# Log rotation: daily, keep 30 days, compress old logs
COPY docker/logrotate-nginx.conf /etc/logrotate.d/nginx

# Entrypoint auto-selects HTTP or HTTPS based on cert presence
COPY docker/entrypoint.sh /entrypoint.sh

# Copy built frontend
COPY --from=builder /app/packages/web/dist/breatic /usr/share/nginx/html

EXPOSE 80 443

ENTRYPOINT ["/entrypoint.sh"]
