# Breatic AI — Local Development
#
# cp .env.dev .env
# docker compose up -d postgres redis
# pnpm dev
#
# Keys marked [REQUIRED] must be set for the service to start.
# Keys marked [RECOMMENDED] enable core features.
# Keys marked [OPTIONAL] enable additional features.

# ╔══════════════════════════════════════════════════╗
# ║  BACKEND (API + Collab + Worker)                 ║
# ╚══════════════════════════════════════════════════╝

# ── App ──────────────────────────────────────────
ENV=dev
DEBUG=false
PORT=3000

# ── Auth [REQUIRED] ─────────────────────────────
SESSION_SECRET_KEY=change-me-in-production    # Any random string, min 16 chars
LOGIN_MODE=WithAccount                         # WithAccount or NoAccount

# ── Database [REQUIRED] ─────────────────────────
DATABASE_URL=postgres://breatic:breatic@localhost:5432/breatic
DB_POOL_SIZE=10

# ── Redis [REQUIRED] ────────────────────────────
# Three logical connections, isolated by DB number.
REDIS_URL=redis://localhost:6379/0               # Session, lock, rate-limit
REDIS_QUEUE_URL=redis://localhost:6379/1          # BullMQ task queue
REDIS_STREAM_URL=redis://localhost:6379/2         # Redis Streams + Hocuspocus pub/sub

# ── CORS ─────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8000           # Vite dev server port

# ── LLM (Agent Chat) [RECOMMENDED] ──────────────
OPENROUTER_API_KEY=                            # openrouter.ai — covers Claude/GPT/Gemini/DeepSeek
ANTHROPIC_API_KEY=                             # Direct Claude access (optional if using OpenRouter)
OPENAI_API_KEY=                                # Direct GPT access (optional if using OpenRouter)
GOOGLE_API_KEY=                                # Direct Gemini access + Nano Banana image models

# ── AIGC Image [OPTIONAL] ───────────────────────
WAVESPEED_API_KEY=                             # wavespeed.ai — ~60 models (image/video/audio/3D)
BYTEPLUS_API_KEY=                              # Seedream image models
DASHSCOPE_API_KEY=                             # Qwen image + Wan video models
TOPAZ_API_KEY=                                 # Topaz image post-processing (upscale/sharpen/denoise)

# ── AIGC Video [OPTIONAL] ───────────────────────
KLINGAI_ACCESS_KEY=                            # Kling video models (requires both access + secret)
KLINGAI_SECRET_KEY=
PIXVERSE_API_KEY=                              # PixVerse video models
VIDU_API_KEY=                                  # Vidu video models
LUMA_API_KEY=                                  # Luma Ray video models

# ── AIGC Audio/TTS [OPTIONAL] ───────────────────
MINIMAX_API_KEY=                               # MiniMax music + Hailuo video + TTS
ELEVENLABS_API_KEY=                            # ElevenLabs TTS + music + SFX
FAL_API_KEY=                                   # fal.ai — F5 TTS, misc models

# ── Agent Tools [OPTIONAL] ──────────────────────
BRAVE_SEARCH_API_KEY=                          # Web search tool for Agent

# ── Payment [OPTIONAL] ──────────────────────────
PAYMENT_ENABLED=false
STRIPE_SECRET_KEY=                             # Stripe secret key (sk_test_... or sk_live_...)
STRIPE_WEBHOOK_SECRET=                         # Stripe webhook signing secret (whsec_...)
CREDIT_MULTIPLIER=1.0                          # Credits per 1000 tokens / per API cent

# ── Storage [OPTIONAL] ──────────────────────────
STORAGE_PROVIDER=local
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
OSS_BUCKET=
OSS_ENDPOINT=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=

# ── Email [OPTIONAL] ────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Google OAuth [OPTIONAL] ─────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ╔══════════════════════════════════════════════════╗
# ║  FRONTEND (Vite — must be prefixed with VITE_)   ║
# ╚══════════════════════════════════════════════════╝

# ── Backend API URL [REQUIRED] ───────────────────
VITE_API_URL=http://localhost:3000

# ── Hocuspocus WebSocket URL [REQUIRED] ──────────
VITE_WS_URL=ws://localhost:1234

# ── Page Navigation Base URL ─────────────────────
VITE_BASE_URL=http://localhost:8000

# ── App Version ──────────────────────────────────
VITE_APP_VERSION=0.1.0

# ── Sentry Error Tracking [OPTIONAL] ────────────
VITE_SENTRY_DSN=
