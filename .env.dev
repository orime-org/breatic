# Breatic AI — Local Development
#
# Usage:
#   cp .env.dev .env
#   docker compose up -d postgres redis
#   pnpm dev
#
# Legend:
#   [REQUIRED]    — must be set, app refuses to start without it
#   [RECOMMENDED] — core features won't work without it
#   [OPTIONAL]    — enables extra features, safe to leave empty

# ╔══════════════════════════════════════════════════╗
# ║  BACKEND (API + Collab + Worker)                 ║
# ╚══════════════════════════════════════════════════╝

# ── App ──────────────────────────────────────────
ENV=dev                                          # dev | staging | prod — controls log level, safety checks
DEBUG=false                                      # true = debug-level logs (verbose), false = info-level
PORT=3000                                        # API server listen port

# ── Auth [REQUIRED] ─────────────────────────────
SESSION_SECRET_KEY=change-me-in-production       # Session signing key. Any random string, min 16 chars
LOGIN_MODE=WithAccount                           # WithAccount = email/password + Google OAuth
                                                 # NoAccount = skip auth (dev only, forbidden in prod)

# ── Database [REQUIRED] ─────────────────────────
DATABASE_URL=postgres://breatic:breatic@localhost:5432/breatic  # Local dev: localhost (Docker PG)
DB_POOL_SIZE=10                                  # Max concurrent DB connections per service

# ── Redis [REQUIRED] ────────────────────────────
# Three logical connections on one Redis instance, isolated by DB number.
# At scale, swap to separate Redis instances — just change URLs, no code changes.
REDIS_URL=redis://localhost:6379/0               # DB 0: session, canvas lock, rate-limit
REDIS_QUEUE_URL=redis://localhost:6379/1          # DB 1: BullMQ task queue (API → Worker)
REDIS_STREAM_URL=redis://localhost:6379/2         # DB 2: Redis Streams + Hocuspocus cross-instance pub/sub

# ── CORS ─────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8000             # Vite dev server origin (port 8000, see packages/web/vite.config.ts)
                                                 # Docker deployment doesn't need this (Nginx proxies same origin)

# ── LLM (Agent Chat) [RECOMMENDED] ──────────────
# At least one LLM key needed for Agent chat. OpenRouter recommended (one key covers all models).
OPENROUTER_API_KEY=                              # openrouter.ai — Claude, GPT, Gemini, DeepSeek via unified API
ANTHROPIC_API_KEY=                               # Direct Claude access (optional if using OpenRouter)
OPENAI_API_KEY=                                  # Direct GPT access (optional if using OpenRouter)
GOOGLE_API_KEY=                                  # Direct Gemini access + image generation models

# ── AIGC Image [OPTIONAL] ───────────────────────
WAVESPEED_API_KEY=                               # wavespeed.ai — ~60 models (image/video/audio/3D)
BYTEPLUS_API_KEY=                                # Seedream image models
DASHSCOPE_API_KEY=                               # Alibaba Qwen image + Wan video models
TOPAZ_API_KEY=                                   # Topaz image post-processing (upscale/sharpen/denoise)

# ── AIGC Video [OPTIONAL] ───────────────────────
KLINGAI_ACCESS_KEY=                              # Kling video models (requires both access + secret)
KLINGAI_SECRET_KEY=
PIXVERSE_API_KEY=                                # PixVerse video models
VIDU_API_KEY=                                    # Vidu video models
LUMA_API_KEY=                                    # Luma Ray video models

# ── AIGC Audio/TTS [OPTIONAL] ───────────────────
MINIMAX_API_KEY=                                 # MiniMax music + Hailuo video + TTS
ELEVENLABS_API_KEY=                              # ElevenLabs TTS + music + SFX
FAL_API_KEY=                                     # fal.ai — F5 TTS, misc models
FISH_API_KEY=                                    # Fish Audio TTS

# ── Agent Tools [OPTIONAL] ──────────────────────
BRAVE_SEARCH_API_KEY=                            # Web search tool for Agent chat
FILE_TOOL_SANDBOX_DIR=                           # Agent file tool sandbox root (default: <monorepo>/uploads/workspace)

# ── Payment [OPTIONAL] ──────────────────────────
PAYMENT_ENABLED=false                            # true = Stripe credit billing, false = unlimited credits
STRIPE_SECRET_KEY=                               # Stripe secret key (sk_test_... or sk_live_...)
STRIPE_WEBHOOK_SECRET=                           # Stripe webhook signing secret (whsec_...)
CREDIT_MULTIPLIER=1.0                            # Credits per 1000 tokens / per API cent

# ── Storage [OPTIONAL] ──────────────────────────
# Controls where AIGC-generated files (images, videos, audio) are stored.
# local: filesystem ./uploads/ (default, zero config, fine for dev)
# s3: AWS S3 / MinIO / Cloudflare R2
# aliyun_oss: Alibaba Cloud OSS
STORAGE_PROVIDER=local                           # local | s3 | aliyun_oss
UPLOAD_BASE_URL=                                 # CDN prefix for file URLs (e.g. https://cdn.example.com)
                                                 # Leave empty: local → http://localhost:3000/uploads
LOCAL_UPLOAD_DIR=                                 # Override local upload dir (default: <monorepo>/uploads)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
OSS_BUCKET=
OSS_ENDPOINT=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=

# ── Upload Size Limits (MB) [OPTIONAL] ──────────
# Per-asset-kind upload size limits. Defaults shown.
# UPLOAD_MAX_IMAGE_MB=50
# UPLOAD_MAX_VIDEO_MB=1024
# UPLOAD_MAX_AUDIO_MB=100
# UPLOAD_MAX_3D_MB=200
# UPLOAD_MAX_DOCUMENT_MB=20

# ── Email [OPTIONAL] ────────────────────────────
# Required for password reset emails. Without SMTP, forgot-password API
# still returns success (anti-enumeration) but no email is sent.
SMTP_HOST=                                       # e.g. smtp.gmail.com
SMTP_PORT=587                                    # 587 (TLS) or 465 (SSL)
SMTP_USER=                                       # SMTP username / email
SMTP_PASSWORD=                                   # SMTP password or app-specific password

# ── Google OAuth [OPTIONAL] ─────────────────────
# Configure at https://console.cloud.google.com/apis/credentials
# Add http://localhost:8000 to authorized JavaScript origins
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ╔══════════════════════════════════════════════════╗
# ║  FRONTEND (Vite — baked at build time)           ║
# ╚══════════════════════════════════════════════════╝
#
# Frontend API/WebSocket host is NOT configured here — the bundle uses
# relative URLs (`/api/*`, `/ws`) and resolves them against
# window.location at runtime. In dev, Vite's server.proxy forwards
# these to localhost:3000 and localhost:1234. In prod, nginx does the
# same job.

# ── App Version ──────────────────────────────────
VITE_APP_VERSION=0.1.0

# ── Sentry Error Tracking [OPTIONAL] ────────────
VITE_SENTRY_DSN=                                 # Sentry DSN for frontend error tracking
