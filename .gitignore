# Dependencies
node_modules/

# Build output
dist/
.turbo/
*.tsbuildinfo

# Environment
.env

# SSL certificates (never commit)
docker/certs/*
!docker/certs/README.md
.env.local
.env.*.local

# IDE
.vscode/
.idea/
.trae

# OS
.DS_Store

# Test & coverage
coverage/
.pytest_cache/

# Documentation build (site generators)
site/

# Logs
*.log
logs/*
!logs/.gitignore

# Uploads (user creates from uploads.example/)
uploads/

# Agent file-tool sandbox (FILE_TOOL_SANDBOX_DIR default; runtime scratch)
sandbox/

# Worktrees (optional parallel dev setup, see docs/WORKTREE.md)
worktrees/

# Claude Code local config
.claude/
.remember/
CLAUDE.local.md
# Private task store: completed-task json archive + index (kept out of the sensitive .claude/ path)
/tasks/

# Playwright MCP cache
.playwright-mcp/

# TypeDoc output (generated, per-package under api-reference/)
api-reference/

# Local brainstorm/preview cache (not part of the public repo)
.superpowers/
.gstack/

# watcher project-level config — private to each contributor, do not commit
.watcher/

# Local dev test-account credentials (throwaway localhost accounts for smoke/e2e; never commit)
/test_account
