{
  "name": "breatic",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "dev:server": "pnpm --filter @breatic/server dev",
    "dev:collab": "pnpm --filter @breatic/collab dev",
    "dev:worker": "pnpm --filter @breatic/worker dev",
    "start": "node packages/server/dist/index.js",
    "start:collab": "node packages/collab/dist/index.js",
    "start:worker": "node packages/worker/dist/index.js",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "lint": "turbo run lint",
    "lint:dependency-cruiser": "depcruise --config .dependency-cruiser.cjs packages/*/src",
    "lint:hover": "bash scripts/lint-hover-pattern.sh",
    "lint:no-brand-usage": "bash scripts/lint-no-brand-usage.sh",
    "lint:no-raw-design-values": "bash scripts/lint-no-raw-design-values.sh",
    "lint:no-extreme-token-value": "bash scripts/lint-no-extreme-token-value.sh && bash scripts/lint-no-extreme-token-value.sh --self-test",
    "lint:1px-border": "bash scripts/lint-1px-border.sh",
    "lint:active-border": "bash scripts/lint-active-border.sh",
    "lint:no-inline-scrollbar": "bash scripts/lint-no-inline-scrollbar.sh",
    "lint:no-native-rendered-ui": "bash scripts/lint-no-native-rendered-ui.sh && bash scripts/lint-no-native-rendered-ui.sh --self-test",
    "lint:single-tooltip-provider": "bash scripts/lint-single-tooltip-provider.sh",
    "lint:single-toast-entry": "bash scripts/lint-single-toast-entry.sh",
    "lint:overlay-surface": "bash scripts/lint-overlay-surface.sh",
    "lint:no-cjk": "bash scripts/lint-no-cjk.sh",
    "lint:no-collab-auth-table-sql": "bash scripts/lint-no-collab-auth-table-sql.sh",
    "lint:no-core-process-env": "bash scripts/lint-no-core-process-env.sh",
    "lint:no-cors-wildcard-credentials": "bash scripts/lint-no-cors-wildcard-credentials.sh",
    "lint:no-drizzle-type-leak": "bash scripts/lint-no-drizzle-type-leak.sh",
    "lint:no-hardcoded-secrets": "bash scripts/lint-no-hardcoded-secrets.sh",
    "lint:no-library-logger": "bash scripts/lint-no-library-logger.sh",
    "lint:no-library-process-exit": "bash scripts/lint-no-library-process-exit.sh",
    "lint:service-logging": "bash scripts/lint-service-logging.sh",
    "lint:no-missing-license-header": "bash scripts/lint-no-missing-license-header.sh",
    "lint:no-raw-sql-outside-repo": "bash scripts/lint-no-raw-sql-outside-repo.sh",
    "lint:no-yjs-documents-sql-outside-repo": "bash scripts/lint-no-yjs-documents-sql-outside-repo.sh",
    "lint:no-postgres-outside-core": "bash scripts/lint-no-postgres-outside-core.sh",
    "lint:no-ioredis-outside-core": "bash scripts/lint-no-ioredis-outside-core.sh",
    "lint:no-param-as-string": "bash scripts/lint-no-param-as-string.sh",
    "lint:no-relative-import": "bash scripts/lint-no-relative-import.sh",
    "lint:no-sync-in-request-path": "bash scripts/lint-no-sync-in-request-path.sh",
    "lint:no-trojan-source": "bash scripts/lint-no-trojan-source.sh",
    "lint:no-translated-product-noun": "bash scripts/lint-no-translated-product-noun.sh",
    "lint:schema-timestamps": "bash scripts/lint-schema-timestamps.sh",
    "lint:no-unresolved-alias-in-dist": "bash scripts/lint-no-unresolved-alias-in-dist.sh",
    "lint:storage-key-prefix": "bash scripts/lint-storage-key-prefix.sh",
    "lint:test-file-location": "bash scripts/lint-test-file-location.sh && bash scripts/lint-test-file-location.sh --self-test",
    "typecheck": "turbo run typecheck",
    "docs": "turbo run docs",
    "clean": "turbo run clean",
    "prepare": "git config core.hooksPath .husky || true"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "anti-trojan-source": "^1.11.3",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^10.1.0",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^63.0.1",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "secretlint": "^13.0.2",
    "tsx": "^4.19.0",
    "turbo": "^2.4.0",
    "typedoc": "^0.28.18",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.58.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.10.1"
    }
  }
}
