{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "dependsOn": ["//#predev", "^build"],
      "cache": false,
      "persistent": true
    },
    "predev": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test": {
      "dependsOn": ["build"],
      "cache": false
    },
    "test:integration": {
      "dependsOn": ["build"],
      "cache": false
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "docs": {
      "dependsOn": ["build"],
      "outputs": ["../../api-reference/**"]
    },
    "clean": {
      "cache": false
    }
  },
  "globalDependencies": [".env"]
}
