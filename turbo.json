{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "SESSION_SECRET_KEY",
    "DATABASE_URL",
    "YJS_DATABASE_URL",
    "REDIS_URL",
    "REDIS_QUEUE_URL",
    "REDIS_STREAM_URL",
    "NODE_ENV",
    "ENV",
    "EMAIL_BACKEND",
    "SMTP_HOST",
    "SMTP_PORT",
    "SMTP_USER",
    "SMTP_PASSWORD",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"],
      "cache": false
    },
    "test:integration": {
      "dependsOn": ["build"],
      "cache": false
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "docs": {
      "dependsOn": ["build"],
      "outputs": ["../../api-reference/**"]
    },
    "clean": {
      "cache": false
    }
  },
  "globalDependencies": [".env"]
}
